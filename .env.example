# Loopback bridge. Never bind this service to 0.0.0.0.
PORT=18790
EXTENSION_ID=replace-after-loading-unpacked-extension
PAIRING_CODE=replace-with-a-random-one-time-code
SESSION_TTL_SECONDS=900
DATA_DIR=./data

# Existing OpenClaw-compatible chat endpoint. Keep its secret in the backend only.
OPENCLAW_API_URL=http://127.0.0.1:20128/v1
OPENCLAW_MODEL=default
OPENCLAW_API_KEY=

# Composio CLI tool slug confirmed for the connected LinkedIn integration.
COMPOSIO_LINKEDIN_SEARCH_TOOL=
COMPOSIO_LINKEDIN_SEARCH_ARGS={}
JOB_SOURCE_MODE=fixture
