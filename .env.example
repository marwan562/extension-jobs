# Loopback bridge. Never bind this service to 0.0.0.0.
PORT=18790
EXTENSION_ID=replace-after-loading-unpacked-extension
PAIRING_CODE=replace-with-a-random-one-time-code
SESSION_TTL_SECONDS=900
DATA_DIR=./data

# Existing Google Chrome started manually with remote debugging. Production
# Wuzzuf automation connects to this endpoint and reuses its first context/profile.
CHROME_CDP_ENDPOINT=http://127.0.0.1:9222
WUZZUF_NAVIGATION_TIMEOUT_MS=60000
WUZZUF_SCREENSHOT_DIR=./.data/wuzzuf-diagnostics
WUZZUF_USER_ID=local-user

# Chat and model discovery use OpenClaw's authenticated Gateway configuration.
# 9Router remains configured inside OpenClaw at http://127.0.0.1:20128/v1.
OPENCLAW_AGENT_ID=main
OPENCLAW_SESSION_KEY=agent:main:extension-job-copilot
OPENCLAW_TIMEOUT_SECONDS=120
# OPENCLAW_MODE=development
OPENCLAW_JOB_TOOL_TOKEN=replace-with-a-separate-random-backend-token
COMPOSIO_JOBS_TOOL_TOKEN=replace-with-a-different-random-backend-token
# Deprecated migration alias: COMPOSIO_WUZZUF_TOOL_TOKEN
# Default agent scopes intentionally exclude applications:submit and applications:approve.
# OPENCLAW_JOB_TOOL_SCOPES=profile:read,jobs:search,applications:prepare,applications:fill,applications:review,campaigns:read,campaigns:manage,audit:read,admin:emergency-stop
# COMPOSIO_JOBS_TOOL_SCOPES=profile:read,jobs:search,applications:prepare,applications:fill,applications:review,audit:read

# Persistent local Composio session host. Keep both services on loopback.
COMPOSIO_ORGANIZATION_API_KEY=oak_gxR0-EGe9v3_rEzrEnrI
COMPOSIO_API_KEY=replace-with-your-composio-api-key
COMPOSIO_USER_ID=local-user
COMPOSIO_HOST_TOKEN=replace-with-a-random-token-at-least-32-characters
COMPOSIO_HOST_PORT=18791
COMPOSIO_SESSION_FILE=./.data/composio-session.json
COMPOSIO_TOOLKITS=wuzzuf,linkedin
WUZZUF_ORCHESTRATOR_URL=http://127.0.0.1:18790

# Composio CLI tool slug confirmed for the connected LinkedIn integration.
COMPOSIO_LINKEDIN_SEARCH_TOOL=
COMPOSIO_LINKEDIN_SEARCH_ARGS={}
JOB_SOURCE_MODE=fixture

# Deprecated/unused in production CDP mode: WUZZUF_DATA_DIR,
# WUZZUF_HEADLESS, WUZZUF_BROWSER_CHANNEL, WUZZUF_EXECUTABLE_PATH.
