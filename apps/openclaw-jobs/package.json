{
  "name": "@extension-jobs/openclaw-jobs",
  "version": "1.0.0-rc.1",
  "description": "Local-first Extension Jobs tools and bundled OpenClaw skill.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marwan562/extension-jobs.git",
    "directory": "apps/openclaw-jobs"
  },
  "homepage": "https://github.com/marwan562/extension-jobs#readme",
  "bugs": {
    "url": "https://github.com/marwan562/extension-jobs/issues"
  },
  "keywords": [
    "openclaw",
    "jobs",
    "resume",
    "local-first",
    "job-search"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "skills"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "plugin:build": "npm run build && openclaw plugins build --root . --entry ./dist/index.js",
    "plugin:validate": "openclaw plugins validate --root . --entry ./dist/index.js"
  },
  "dependencies": {
    "typebox": "^1.3.6"
  },
  "peerDependencies": {
    "openclaw": ">=2026.7.1"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  }
}
