{
  "name": "@extension-jobs/cli",
  "version": "1.0.0-rc.1",
  "description": "Local setup and administration CLI for Extension Jobs.",
  "type": "module",
  "license": "MIT",
  "private": false,
  "engines": { "node": ">=24" },
  "repository": { "type": "git", "url": "git+https://github.com/marwan562/extension-jobs.git", "directory": "apps/cli" },
  "bin": { "extension-jobs": "./dist/index.js" },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node24 --external:mammoth --external:pdf-parse --external:yaml --outfile=dist/index.js",
    "prepack": "npm run build"
  },
  "dependencies": {
    "mammoth": "^1.10.0",
    "pdf-parse": "^2.4.5",
    "yaml": "^2.8.1"
  },
  "keywords": ["jobs", "openclaw", "resume", "cli", "local-first"]
}
