{
  "manifest_version": 3,
  "name": "Extension Jobs Control Center",
  "version": "1.0.0",
  "key": "",
  "description": "Local-first job research and application review control center.",
  "permissions": ["sidePanel", "storage", "activeTab", "scripting"],
  "host_permissions": ["http://127.0.0.1:18790/*"],
  "optional_host_permissions": [
    "https://*.wuzzuf.net/*", "https://*.indeed.com/*", "https://*.linkedin.com/*",
    "https://*.bayt.com/*", "https://*.glassdoor.com/*", "https://*.ziprecruiter.com/*",
    "https://*.greenhouse.io/*", "https://*.lever.co/*", "https://*.ashbyhq.com/*",
    "https://*.workable.com/*", "https://*.smartrecruiters.com/*", "https://*.myworkdayjobs.com/*"
  ],
  "background": { "service_worker": "dist/service-worker.js", "type": "module" },
  "side_panel": { "default_path": "sidepanel.html" },
  "options_page": "options.html",
  "action": { "default_title": "Extension Jobs Control Center" },
  "content_security_policy": { "extension_pages": "script-src 'self'; object-src 'none'" }
}
