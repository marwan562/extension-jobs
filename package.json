{
  "name": "openclaw-job-automation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p apps/extension/tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --experimental-strip-types --test tests/*.test.ts",
    "test:wuzzuf": "node --experimental-strip-types --test tests/wuzzuf-*.test.ts",
    "start": "node --env-file-if-exists=.env --experimental-strip-types apps/orchestrator/src/main.ts",
    "start:mock-site": "node --experimental-strip-types apps/playwright-worker/src/main.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.0.0",
    "playwright": "^1.42.1",
    "typescript": "^5.9.0"
  },
  "dependencies": {
    "@composio/core": "^0.13.1",
    "cheerio": "^1.2.0",
    "pdf-parse": "^2.4.5",
    "typebox": "^1.3.6",
    "zod": "^3.25.76"
  }
}
